###
# 17. ถอดรหัส Profile (ใส่ ID ของ testuser1 หรือ testuser2)
POST {{baseUrl}}/decode
Content-Type: application/json

{
  "id": "b455863d-0c7b-4e88-9c6d-c09b3cfa4a58"
}

###
# 18. ถอดรหัส Profile ที่ไม่มี
POST {{baseUrl}}/decode
Content-Type: application/json

{
  "id": "non-existent-id"
}

###
# 19. ถอดรหัสโดยไม่ใส่ ID
POST {{baseUrl}}/decode
Content-Type: application/json

{}

